VITE_API_BASE_URL=

# 留空时默认走当前域名下的 /api，例如本地 Vite 代理或同域部署。
# 线上前后端分离时可改成 https://your-test-domain.com

# 默认都不启用 mock：读接口失败会直接报错，写接口会走真实 API。
VITE_FORCE_MOCK_READS=false
VITE_ALLOW_MOCK_READ_FALLBACK=false
VITE_FORCE_MOCK_COMMANDS=false

# 仅 demo/dev 演示时再开启：
# VITE_FORCE_MOCK_READS=true 会强制 bootstrap/home/scene 等读接口使用本地演示数据。
# VITE_ALLOW_MOCK_READ_FALLBACK=true 会在部分读接口失败时退回本地演示数据。
# VITE_FORCE_MOCK_COMMANDS=true 会让少数命令走本地模拟，不会写入后端数据库。
