  raidMessage       RaidOrderMessage?

  @@unique([requestIdempotencyKey])
  @@index([attackerPlayerId, status])
  @@index([defenderPlayerId, status])
  @@index([settleAt, status])
  @@map("raid_order")
}

model RaidAssetLock {
  id                String              @id @default(cuid())
  raidOrderId       String              @map("raid_order_id")
  defenderPlayerId  String              @map("defender_player_id")
  assetType         String              @map("asset_type")
  sourceEntityId    String?             @map("source_entity_id")
  sourceFieldSlotId String?             @map("source_field_slot_id")
  lockedGold        Int                 @default(0) @map("locked_gold")
  lockedItemJson    Json?               @map("locked_item_json")
  lockMode          RaidAssetLockMode   @map("lock_mode")
  status            RaidAssetLockStatus @default(ACTIVE)
  expiresAt         DateTime?           @map("expires_at")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  raidOrder       RaidOrder        @relation(fields: [raidOrderId], references: [id], onDelete: Cascade)
  defenderPlayer  Player           @relation("RaidAssetLockDefender", fields: [defenderPlayerId], references: [id], onDelete: Cascade)
  sourceFieldSlot PlayerFieldSlot? @relation(fields: [sourceFieldSlotId], references: [id], onDelete: SetNull)

  @@index([raidOrderId])
  @@index([defenderPlayerId, status])
  @@index([expiresAt, status])
  @@map("raid_asset_lock")
}

model RaidSettlement {
  id                      String               @id @default(cuid())
  raidOrderId             String               @unique @map("raid_order_id")
  result                  RaidSettlementResult
  lootGold                Int                  @default(0) @map("loot_gold")
  depositedGold           Int                  @default(0) @map("deposited_gold")
  overflowGold            Int                  @default(0) @map("overflow_gold")
  temporaryClaimExpiresAt DateTime?            @map("temporary_claim_expires_at")
  attackerLoss            Int                  @default(0) @map("attacker_loss")
  defenderLoss            Int                  @default(0) @map("defender_loss")
  rewardItemsJson         Json?                @map("reward_items_json")
  battleReplayJson        Json?                @map("battle_replay_json")
  reportSummary           String               @map("report_summary")
  createdAt               DateTime             @default(now()) @map("created_at")

  raidOrder RaidOrder @relation(fields: [raidOrderId], references: [id], onDelete: Cascade)

  @@map("raid_settlement")
}

model BattleReport {
  id               String               @id @default(cuid())
  raidOrderId      String               @map("raid_order_id")
  ownerPlayerId    String               @map("owner_player_id")
  opponentPlayerId String               @map("opponent_player_id")
  reportType       BattleReportType     @map("report_type")
  result           RaidSettlementResult
  title            String
  summary          String
  revengeAvailable Boolean              @default(false) @map("revenge_available")
  revokedAt        DateTime?            @map("revoked_at")
  createdAt        DateTime             @default(now()) @map("created_at")

  raidOrder      RaidOrder @relation(fields: [raidOrderId], references: [id], onDelete: Cascade)
  ownerPlayer    Player    @relation("BattleReportOwner", fields: [ownerPlayerId], references: [id], onDelete: Cascade)
  opponentPlayer Player    @relation("BattleReportOpponent", fields: [opponentPlayerId], references: [id], onDelete: Cascade)

  @@index([ownerPlayerId, createdAt])
  @@index([raidOrderId])
  @@map("battle_report")
}
