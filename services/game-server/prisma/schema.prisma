generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  WECHAT
  DEV_FAKE
}

enum ArmyTrainingStatus {
  QUEUED
  FINISHED
  CLAIMED
  CANCELLED
}

enum FieldStatus {
  LOCKED
  EMPTY
  SEEDED
  GROWING
  MATURE
  WITHERED
}

enum TaskStatus {
  IN_PROGRESS
  COMPLETED
  CLAIMED
}

enum DailyFactionTaskType {
  ESSENCE_SUBMIT_BASIC
  ESSENCE_SUBMIT_FOCUS
  CONFLICT_RAID
}

enum RaidOrderMode {
  SINGLE
  BOUNTY
}

enum RaidOrderStatus {
  CREATED
  LOCKED
  SETTLING
  SETTLED
  SETTLEMENT_FAILED
  CANCELLED
  BOUNTY_CREATED
  BOUNTY_WAITING_PARTNER
  BOUNTY_ACCEPTED
  BOUNTY_EXPIRED
}

enum RaidAssetLockMode {
  SOFT
  HARD
}

enum RaidAssetLockStatus {
  ACTIVE
  RELEASED
  CONSUMED
  EXPIRED
}

enum RaidSettlementResult {
  WIN
  LOSS
  DRAW
  CANCELLED
}

enum BattleReportType {
  ATTACK
  DEFENSE
  BOUNTY
}

enum SpiritRarity {
  COMMON
  RARE
  LEGENDARY
}

enum SpiritRole {
  ATTACK
  BALANCED
  HEALTH
}

enum SpiritElement {
  METAL
  WOOD
  WATER
  FIRE
  EARTH
}

enum PlayerSpiritStatus {
  ACTIVE
  WOUNDED
  RESTING
  DISSOLVED
}

enum NotificationAudience {
  GLOBAL
  PLAYER
}

enum NotificationCategory {
  SYSTEM
  ANNOUNCEMENT
  MAINTENANCE
  REWARD
  COMPENSATION
}

enum PlayerNotificationClaimStatus {
  NONE
  UNCLAIMED
  CLAIMED
  EXPIRED
}

enum SocialRelationType {
  FRIEND
  FOLLOWING
  ENEMY
  BLOCKED
}

enum SocialRelationStatus {
  ACTIVE
  PENDING
  MUTED
}

enum SocialFeedType {
  FRIEND_WATERED_FIELD
  FRIEND_GUARDED_FIELD
  FRIEND_REQUESTED
  FRIEND_ACCEPTED
  FRIEND_REJECTED
  TEAM_CHALLENGE_INVITED
  TEAM_CHALLENGE_ACCEPTED
  ENEMY_RAIDED
  REVENGE_AVAILABLE
  FACTION_HELP_REQUESTED
}

enum SocialAssistType {
  WATER_FIELD
  GUARD_FIELD
  RECOVER_SPIRIT
  FACTION_TASK_HELP
}

enum TeamChallengeStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  SETTLED
}

enum ShareAssistCampaignType {
  WATER
  FRIEND_INVITE
}

enum ShareAssistCampaignStatus {
  ACTIVE
  FULL
  EXPIRED
  CANCELLED
}

enum ShareAssistRecordAudience {
  GUEST
  PLAYER
}

enum ShareAssistRecordStatus {
  CONFIRMED
  BOUND
  REWARDED
  REJECTED
}

enum PlayerInviteRelationStatus {
  PENDING_BIND
  BOUND
  TUTORIAL_COMPLETED
  REWARDED
  INVALID
}

model Player {
  id               String    @id @default(cuid())
  nickname         String
  avatarUrl        String?   @map("avatar_url")
  factionId        String?   @map("faction_id")
  castleLevelCache Int       @default(1) @map("castle_level_cache")
  lastLoginAt      DateTime? @map("last_login_at")
  protectedUntil   DateTime? @map("protected_until")
  stateVersion     Int       @default(1) @map("state_version")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  authIdentities          PlayerAuthIdentity[]
  army                    PlayerArmy?
  buildings               PlayerBuilding?
  faction                 Faction?                 @relation("PlayerFaction", fields: [factionId], references: [id], onDelete: SetNull)
  factionMembers          FactionMember[]
  factionContributionLogs FactionContributionLog[]
  walletChangeLogs        WalletChangeLog[]
  buildingUpgradeLogs     BuildingUpgradeLog[]
  fieldHarvestLogs        FieldHarvestLog[]
  fieldSlots              PlayerFieldSlot[]
  seedInventory           PlayerSeedInventory[]
  plantResearch           PlayerPlantResearch[]
  dailyFactionTasks       DailyFactionTask[]
  essenceTransactionLogs  EssenceTransactionLog[]
  spiritCodex             PlayerSpiritCodex[]
  spiritFeedLogs          SpiritFeedLog[]
  spiritBreakthroughLogs  SpiritBreakthroughLog[]
  spiritTraitRollLogs     SpiritTraitRollLog[]
  spiritShopPurchaseLogs  SpiritShopPurchaseLog[]
  spiritAdRewardLogs      SpiritAdRewardLog[]
  spiritResource          PlayerSpiritResource?
  spiritSlots             PlayerSpiritSlot[]
  farmBoard               PlayerFarmBoard?
  raidMessagesAuthored    RaidOrderMessage[]       @relation("RaidOrderMessageAuthor")
  raidMessagesReceived    RaidOrderMessage[]       @relation("RaidOrderMessageReceiver")
  taskStates              PlayerDailyTaskState[]
  taskRewardLogs          TaskRewardLog[]
  idempotencyRecords      IdempotencyRecord[]
  trainingQueues          ArmyTrainingQueue[]
  wallet                  PlayerWallet?
  ownedRaidTargetPools    RaidTargetPool[]         @relation("RaidTargetPoolOwner")
  targetRaidTargetPools   RaidTargetPool[]         @relation("RaidTargetPoolTarget")
  attackRaidOrders        RaidOrder[]              @relation("RaidOrderAttacker")
  defendRaidOrders        RaidOrder[]              @relation("RaidOrderDefender")
  raidAssetLocks          RaidAssetLock[]          @relation("RaidAssetLockDefender")
  ownedBattleReports      BattleReport[]           @relation("BattleReportOwner")
  opponentBattleReports   BattleReport[]           @relation("BattleReportOpponent")
  notifications           PlayerNotification[]
  landDeedProgress        PlayerLandDeedProgress[]
  factionStipendStates    PlayerFactionStipendState[]
  socialRelationsOwned    PlayerSocialRelation[]    @relation("SocialRelationOwner")
  socialRelationsTargeted PlayerSocialRelation[]    @relation("SocialRelationTarget")
  socialFeedsOwned        PlayerSocialFeed[]        @relation("SocialFeedOwner")
  socialFeedsAuthored     PlayerSocialFeed[]        @relation("SocialFeedActor")
  assistsGiven            PlayerAssistRecord[]      @relation("AssistHelper")
  assistsReceived         PlayerAssistRecord[]      @relation("AssistTarget")
  teamChallengesStarted   TeamChallenge[]           @relation("TeamChallengeInitiator")
  teamChallengesAllied    TeamChallenge[]           @relation("TeamChallengeAlly")
  teamChallengesTargeted  TeamChallenge[]           @relation("TeamChallengeTarget")
  shareAssistCampaigns    ShareAssistCampaign[]     @relation("ShareAssistCampaignOwner")
  shareAssistRecords      ShareAssistRecord[]       @relation("ShareAssistRecordHelper")
  inviteRelationsSent     PlayerInviteRelation[]    @relation("InviteRelationInviter")
  inviteRelationsReceived PlayerInviteRelation[]    @relation("InviteRelationInvited")

  @@index([factionId])
  @@index([lastLoginAt])
  @@map("player")
}

model PlayerAuthIdentity {
  id             String       @id @default(cuid())
  playerId       String       @map("player_id")
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  unionId        String?      @map("union_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([playerId])
  @@map("player_auth_identity")
}

model Faction {
  id                               String   @id @default(cuid())
  code                             String
  name                             String
  treasuryGold                     Int      @default(0) @map("treasury_gold")
  hourlyBaseDividend               Int      @default(0) @map("hourly_base_dividend")
  hourlyContributionDividendPerTen Int      @default(0) @map("hourly_contribution_dividend_per_ten")
  contributionScore                Int      @default(0) @map("contribution_score")
  createdAt                        DateTime @default(now()) @map("created_at")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  players                 Player[]                 @relation("PlayerFaction")
  members                 FactionMember[]
  factionContributionLogs FactionContributionLog[]
  dailyFactionTasks       DailyFactionTask[]

  @@unique([code])
  @@unique([name])
  @@map("faction")
}

model FactionMember {
  id                String   @id @default(cuid())
  factionId         String   @map("faction_id")
  playerId          String   @map("player_id")
  contributionScore Int      @default(0) @map("contribution_score")
  joinedAt          DateTime @default(now()) @map("joined_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  faction Faction @relation(fields: [factionId], references: [id], onDelete: Cascade)
  player  Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([factionId, playerId])
  @@index([playerId])
  @@map("faction_member")
}

model PlayerLandDeedProgress {
  id           String    @id @default(cuid())
  playerId     String    @map("player_id")
  deedKey      String    @map("deed_key")
  status       String    @default("in_progress")
  progressJson Json      @map("progress_json")
  claimedAt    DateTime? @map("claimed_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, deedKey])
  @@index([playerId, status])
  @@map("player_land_deed_progress")
}

model PlayerFactionStipendState {
  id                   String    @id @default(cuid())
  playerId             String    @map("player_id")
  dateKey              String    @map("date_key")
  contributionSnapshot Int       @map("contribution_snapshot")
  tierKey              String    @map("tier_key")
  rewardJson           Json      @map("reward_json")
  claimedAt            DateTime? @map("claimed_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([playerId, dateKey])
  @@index([dateKey, claimedAt])
  @@index([playerId, claimedAt])
  @@map("player_faction_stipend_state")
}

model PlayerWallet {
  playerId                     String    @id @map("player_id")
  vaultGold                    Int       @default(0) @map("vault_gold")
  vaultCapacity                Int       @default(0) @map("vault_capacity")
  walletGold                   Int       @default(0) @map("wallet_gold")
  walletCapacity               Int       @default(0) @map("wallet_capacity")
  walletProtectedRatio         Int       @default(0) @map("wallet_protected_ratio")
  pendingTaxGold               Int       @default(0) @map("pending_tax_gold")
  pendingDividendGold          Int       @default(0) @map("pending_dividend_gold")
  pendingRaidOverflowGold      Int       @default(0) @map("pending_raid_overflow_gold")
  pendingRaidOverflowExpiresAt DateTime? @map("pending_raid_overflow_expires_at")
  passiveSettledAt             DateTime? @map("passive_settled_at")
  balanceVersion               Int       @default(1) @map("balance_version")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([pendingRaidOverflowExpiresAt])
  @@map("player_wallet")
}

model PlayerBuilding {
  playerId              String   @id @map("player_id")
  castleLevel           Int      @default(1) @map("castle_level")
  vaultLevel            Int      @default(1) @map("vault_level")
  fieldSlotLevel        Int      @default(1) @map("field_slot_level")
  populationLevel       Int      @default(1) @map("population_level")
  watchtowerLevel       Int      @default(1) @map("watchtower_level")
  protectionTechLevel   Int      @default(0) @map("protection_tech_level")
  farmYieldTechLevel    Int      @default(0) @map("farm_yield_tech_level")
  ripeWindowTechLevel   Int      @default(0) @map("ripe_window_tech_level")
  pendingClaimTechLevel Int      @default(0) @map("pending_claim_tech_level")
  buildingVersion       Int      @default(1) @map("building_version")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_building")
}

model PlayerArmy {
  playerId       String   @id @map("player_id")
  totalCount     Int      @default(0) @map("total_count")
  availableCount Int      @default(0) @map("available_count")
  frozenCount    Int      @default(0) @map("frozen_count")
  woundedCount   Int      @default(0) @map("wounded_count")
  capacity       Int      @default(0)
  armyVersion    Int      @default(1) @map("army_version")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_army")
}

model ArmyTrainingQueue {
  id            String             @id @default(cuid())
  playerId      String             @map("player_id")
  queuedCount   Int                @map("queued_count")
  unitCostGold  Int                @map("unit_cost_gold")
  totalCostGold Int                @map("total_cost_gold")
  startedAt     DateTime           @map("started_at")
  finishAt      DateTime           @map("finish_at")
  status        ArmyTrainingStatus @default(QUEUED)
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, status])
  @@index([finishAt])
  @@map("army_training_queue")
}

model SeedDefinition {
  id                String   @id @default(cuid())
  seedId            String   @map("seed_id")
  label             String
  rarity            String
  sortOrder         Int      @default(0) @map("sort_order")
  seedSeconds       Int      @map("seed_seconds")
  growSeconds       Int      @map("grow_seconds")
  matureSeconds     Int      @map("mature_seconds")
  ripeWindowSeconds Int      @map("ripe_window_seconds")
  baseYieldGold     Int      @map("base_yield_gold")
  harvestSeedReturn Int      @default(0) @map("harvest_seed_return")
  strategyNote      String?  @map("strategy_note")
  lore              String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  fieldSlots      PlayerFieldSlot[]
  playerInventory PlayerSeedInventory[]
  plantResearch   PlayerPlantResearch[]

  @@unique([seedId])
  @@index([rarity, sortOrder])
  @@map("seed_definition")
}

model SpiritDefinition {
  id                  String       @id @default(cuid())
  spiritId            String       @map("spirit_id")
  label               String
  rarity              SpiritRarity
  factionAffinity     String       @map("faction_affinity")
  role                SpiritRole
  shardName           String       @map("shard_name")
  shardUnlockRequired Int          @default(100) @map("shard_unlock_required")
  baseAttack          Int          @map("base_attack")
  baseHp              Int          @map("base_hp")
  growthAttack        Int          @map("growth_attack")
  growthHp            Int          @map("growth_hp")
  sortOrder           Int          @default(0) @map("sort_order")
  lore                String?
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  codexEntries PlayerSpiritCodex[]
  spiritSlots  PlayerSpiritSlot[]

  @@unique([spiritId])
  @@index([rarity, sortOrder])
  @@map("spirit_definition")
}

model PlayerSpiritResource {
  playerId                         String   @id @map("player_id")
  spiritSoul                       Int      @default(0) @map("spirit_soul")
  spiritRoot                       Int      @default(0) @map("spirit_root")
  spiritMarrow                     Int      @default(0) @map("spirit_marrow")
  spiritJade                       Int      @default(0) @map("spirit_jade")
  ordinarySoul                     Int      @default(0) @map("ordinary_soul")
  rareSoul                         Int      @default(0) @map("rare_soul")
  legendarySoul                    Int      @default(0) @map("legendary_soul")
  tianjiTalisman                   Int      @default(0) @map("tianji_talisman")
  dailyStarterSeedClaimDateKey     String?  @map("daily_starter_seed_claim_date_key")
  dailyTianjiClaimDateKey          String?  @map("daily_tianji_claim_date_key")
  dailySpiritSoulClaimDateKey      String?  @map("daily_spirit_soul_claim_date_key")
  dailyRecoveryUsed                Int      @default(0) @map("daily_recovery_used")
  dailyRecoveryDateKey             String?  @map("daily_recovery_date_key")
  dailyIntelFreeUsed               Int      @default(0) @map("daily_intel_free_used")
  dailyIntelTalismanUsed           Int      @default(0) @map("daily_intel_talisman_used")
  dailyIntelDateKey                String?  @map("daily_intel_date_key")
  resourceVersion                  Int      @default(1) @map("resource_version")
  createdAt                        DateTime @default(now()) @map("created_at")
  updatedAt                        DateTime @updatedAt @map("updated_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("player_spirit_resource")
}

model PlayerSpiritSlot {
  id                 String             @id @default(cuid())
  playerId           String             @map("player_id")
  slotIndex          Int                @map("slot_index")
  spiritDefinitionId String?            @map("spirit_definition_id")
  isMain             Boolean            @default(false) @map("is_main")
  level              Int                @default(1)
  exp                Int                @default(0)
  breakthroughStage  Int                @default(0) @map("breakthrough_stage")
  satiatedUntil      DateTime?          @map("satiated_until")
  lastExpSettledAt   DateTime?          @map("last_exp_settled_at")
  element            SpiritElement?
  currentHp          Int                @default(0) @map("current_hp")
  maxHp              Int                @default(0) @map("max_hp")
  status             PlayerSpiritStatus @default(ACTIVE)
  acquiredAt         DateTime?          @map("acquired_at")
  dissolvedAt        DateTime?          @map("dissolved_at")
  slotVersion        Int                @default(1) @map("slot_version")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")

  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spiritDefinition SpiritDefinition? @relation(fields: [spiritDefinitionId], references: [id], onDelete: SetNull)
  traits           PlayerSpiritTrait[]
  feedLogs         SpiritFeedLog[]
  breakthroughLogs SpiritBreakthroughLog[]
  traitRollLogs    SpiritTraitRollLog[]

  @@unique([playerId, slotIndex])
  @@index([playerId, isMain])
  @@index([spiritDefinitionId])
  @@map("player_spirit_slot")
}

model PlayerSpiritTrait {
  id          String   @id @default(cuid())
  spiritSlotId String  @map("spirit_slot_id")
  slotIndex   Int      @map("slot_index")
  traitCode   String   @map("trait_code")
  traitValue  Int      @map("trait_value")
  sourceType  String   @map("source_type")
  lockedAt    DateTime? @map("locked_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  spiritSlot PlayerSpiritSlot @relation(fields: [spiritSlotId], references: [id], onDelete: Cascade)

  @@unique([spiritSlotId, slotIndex])
  @@index([spiritSlotId])
  @@index([traitCode])
  @@map("player_spirit_trait")
}

model SpiritFeedLog {
  id                    String   @id @default(cuid())
  playerId              String   @map("player_id")
  spiritSlotId          String   @map("spirit_slot_id")
  actionType            String   @map("action_type")
  feedCount             Int      @map("feed_count")
  satiatedSecondsAdded  Int      @map("satiated_seconds_added")
  immediateExpGain      Int      @map("immediate_exp_gain")
  beforeSatiatedUntil   DateTime? @map("before_satiated_until")
  afterSatiatedUntil    DateTime? @map("after_satiated_until")
  requestIdempotencyKey String?  @map("request_idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  player     Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spiritSlot PlayerSpiritSlot @relation(fields: [spiritSlotId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([spiritSlotId])
  @@index([requestIdempotencyKey])
  @@map("spirit_feed_log")
}

model SpiritBreakthroughLog {
  id                    String   @id @default(cuid())
  playerId              String   @map("player_id")
  spiritSlotId          String   @map("spirit_slot_id")
  fromStage             Int      @map("from_stage")
  toStage               Int      @map("to_stage")
  consumedSoulQuality   String   @map("consumed_soul_quality")
  consumedSoulCount     Int      @map("consumed_soul_count")
  requestIdempotencyKey String?  @map("request_idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  player     Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spiritSlot PlayerSpiritSlot @relation(fields: [spiritSlotId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([spiritSlotId])
  @@index([requestIdempotencyKey])
  @@map("spirit_breakthrough_log")
}

model SpiritTraitRollLog {
  id                    String   @id @default(cuid())
  playerId              String   @map("player_id")
  spiritSlotId          String   @map("spirit_slot_id")
  mode                  String
  lockedSlotIndex       Int?     @map("locked_slot_index")
  targetSlotIndex       Int?     @map("target_slot_index")
  targetTraitCode       String?  @map("target_trait_code")
  consumedJson          Json     @map("consumed_json")
  beforeTraitsJson      Json     @map("before_traits_json")
  resultTraitsJson      Json     @map("result_traits_json")
  candidateResultsJson  Json?    @map("candidate_results_json")
  requestIdempotencyKey String?  @map("request_idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  player     Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spiritSlot PlayerSpiritSlot @relation(fields: [spiritSlotId], references: [id], onDelete: Cascade)

  @@index([playerId, createdAt])
  @@index([spiritSlotId])
  @@index([requestIdempotencyKey])
  @@map("spirit_trait_roll_log")
}

model SpiritShopPurchaseLog {
  id                    String   @id @default(cuid())
  playerId              String   @map("player_id")
  itemId                String   @map("item_id")
  periodKey             String?  @map("period_key")
  consumedTianjiTalisman Int     @map("consumed_tianji_talisman")
  rewardJson            Json     @map("reward_json")
  requestIdempotencyKey String?  @map("request_idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, itemId, periodKey])
  @@map("spirit_shop_purchase_log")
}

model SpiritAdRewardLog {
  id                    String   @id @default(cuid())
  playerId              String   @map("player_id")
  dateKey               String   @map("date_key")
  tianjiTalismanReward  Int      @map("tianji_talisman_reward")
  bonusRewardJson       Json     @map("bonus_reward_json")
  requestIdempotencyKey String?  @map("request_idempotency_key")
  createdAt             DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId, dateKey])
  @@map("spirit_ad_reward_log")
}

model PlayerSpiritCodex {
  id                 String    @id @default(cuid())
  playerId           String    @map("player_id")
  spiritDefinitionId String    @map("spirit_definition_id")
  hasSeen            Boolean   @default(false) @map("has_seen")
  shardCount         Int       @default(0) @map("shard_count")
  readyToCompose     Boolean   @default(false) @map("ready_to_compose")
  ownedCurrent       Boolean   @default(false) @map("owned_current")
  ownedEver          Boolean   @default(false) @map("owned_ever")
  firstSeenAt        DateTime? @map("first_seen_at")
  readyAt            DateTime? @map("ready_at")
  lastOwnedAt        DateTime? @map("last_owned_at")
  codexVersion       Int       @default(1) @map("codex_version")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  player           Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  spiritDefinition SpiritDefinition @relation(fields: [spiritDefinitionId], references: [id], onDelete: Cascade)

  @@unique([playerId, spiritDefinitionId])
  @@index([playerId, readyToCompose])
  @@index([spiritDefinitionId])
  @@map("player_spirit_codex")
}

model PlayerFarmBoard {
  playerId     String    @id @map("player_id")
  message      String    @default("")
  boardVersion Int       @default(1) @map("board_version")
  hiddenAt     DateTime? @map("hidden_at")
  createdAt    DateTime  @default(now()) @map("created_at")
