{
  "name": "@trinitywar/game-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "worker:raid-settlement": "tsx src/raid-settlement.worker.ts",
    "worker:raid-settlement:sweep": "tsx src/raid-settlement-sweep.ts",
    "test:faction-advantages": "tsx src/verification/verify-faction-advantage-formulas.ts",
    "verify:test-flow": "tsx src/verification/verify-test-flow.ts",
    "verify:friend-invite": "tsx src/verification/verify-friend-invite-flow.ts",
    "verify:social-friend": "tsx src/verification/verify-social-friend-flow.ts",
    "build": "node ./scripts/build.mjs",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:validate": "node ./scripts/prisma-validate.mjs",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "@trinitywar/shared": "file:../../packages/shared",
    "bullmq": "^4.18.3",
    "ioredis": "^5.4.1",
    "pino": "^9.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "esbuild": "^0.18.20",
    "prisma": "^5.22.0",
    "tsx": "^3.12.7",
    "typescript": "^5.4.5"
  }
}
